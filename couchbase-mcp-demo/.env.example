# Ollama model used by both the Unfiltered Approach and the Couchbase-filtered approach
# (all LLM inference in this demo is local - no external API key needed)
OLLAMA_MODEL=llama3.1:8b

# Couchbase connection (Docker Compose supplies safe defaults; override for Capella or a remote cluster)
#COUCHBASE_CONNECTION_STRING=couchbases://your-cluster-address
#COUCHBASE_USERNAME=Administrator
#COUCHBASE_PASSWORD=CouchbaseDemo123!
