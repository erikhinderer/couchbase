# Copy this file to `.env` in the project root before running `docker compose up`:
#   cp env.example .env
#
# --- App ---
ENVIRONMENT=development
LOG_LEVEL=INFO

# --- Local LLM: Qwen 3.8 (Qwen 3, 8B), served via Ollama-compatible API ---
QWEN_BASE_URL=http://qwen-service:11434
QWEN_MODEL_NAME=qwen3:8b

# --- Embedding service ---
EMBEDDING_SERVICE_BASE_URL=http://embedding-service:8500

# --- Vectorizer engine tuning ---
DEFAULT_BATCH_SIZE=32
DEFAULT_POLL_INTERVAL_SECONDS=3.0
DEFAULT_VECTOR_FIELD_NAME=embedding
